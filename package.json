  "license": "MIT",
  "devDependencies": {
    "nodemon": "^3",
    "prettier": "^3",
    "ts-add-js-extension": "^1",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4"
  }
}
