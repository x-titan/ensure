{
  "name": "@x-titan/ensure",
  "version": "0.1.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "start": "node dist",
    "build": "tsc && tsup && ts-add-js-extension --dir=dist",
